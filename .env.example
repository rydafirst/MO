# Mobile -> backend connection.
# Simulator/web: localhost works. On a physical device, replace with your machine's LAN IP,
# e.g. http://192.168.1.20:4000  (both device and computer on the same Wi-Fi).
EXPO_PUBLIC_API_URL=http://localhost:4000/v1
EXPO_PUBLIC_WS_URL=http://localhost:4000

# Google Places autocomplete for the address fields (same key family as the web).
# Enable Places API + Geocoding API. The key must NOT be restricted to HTTP referrers
# (mobile calls have none); restrict by API and, ideally, by iOS bundle id ng.rydafirst.app.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
