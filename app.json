{
  "expo": {
    "name": "Rydafirst",
    "slug": "rydafirst",
    "scheme": "rydafirst",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ng.rydafirst.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Rydafirst uses your location so customers can track your delivery and you can confirm pickup and drop-off.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Rydafirst shares your live location with the customer while a delivery is active."
      }
    },
    "android": {
      "package": "ng.rydafirst.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F0F"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Rydafirst uses your location so customers can track your delivery and you can confirm pickup and drop-off."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3aab2310-4723-4aad-802c-a57f5fe3c55d"
      }
    },
    "owner": "rydas-team"
  }
}
