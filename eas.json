{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://be-production-e8e9.up.railway.app/v1",
        "EXPO_PUBLIC_WS_URL": "https://be-production-e8e9.up.railway.app"
      },
      "ios": { "simulator": true },
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://be-production-e8e9.up.railway.app/v1",
        "EXPO_PUBLIC_WS_URL": "https://be-production-e8e9.up.railway.app"
      },
      "android": { "buildType": "apk" }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://be-production-e8e9.up.railway.app/v1",
        "EXPO_PUBLIC_WS_URL": "https://be-production-e8e9.up.railway.app"
      },
      "android": { "buildType": "app-bundle" }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "itsolonts@gmail.com",
        "appleTeamId": "5S974CVZ88"
      },
      "android": {
        "serviceAccountKeyPath": "./play-service-account.json",
        "track": "internal"
      }
    }
  }
}
